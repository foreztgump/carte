---
import { formatAllergens, formatCurrency, formatDietaryTags } from "../format.js";
import { itemClassesFor } from "../styles.js";
import type { MenuItemProps } from "../types.js";

const props = Astro.props as MenuItemProps;
const { item, variant = "default" } = props;
const itemClass = itemClassesFor(variant);
const hasAllergens = item.allergens.length > 0;
const dietaryTags = item.dietaryTags ?? [];
---

<article
  class={itemClass}
  data-allergens={item.allergens.join(" ")}
  data-carte-menu-item
  data-carte-variant={variant}
  id={item.id}
>
  <div class={variant === "headless" ? undefined : "flex items-start justify-between gap-4"}>
    <div>
      <h3 class={variant === "headless" ? undefined : "text-lg font-semibold text-stone-950"}>{item.name}</h3>
      {
        item.description ? (
          <p class={variant === "headless" ? undefined : "mt-1 text-sm leading-6 text-stone-600"}>
            {item.description}
          </p>
        ) : null
      }
    </div>
    <p class={variant === "headless" ? undefined : "shrink-0 font-semibold text-stone-950"}>
      {formatCurrency(item.price, item.currency)}
    </p>
  </div>
  <div class={variant === "headless" ? undefined : "mt-4 flex flex-wrap gap-2 text-xs"}>
    {
      dietaryTags.length > 0 ? (
        <span class={variant === "headless" ? undefined : "rounded-full bg-emerald-50 px-3 py-1 text-emerald-800"}>
          {formatDietaryTags(dietaryTags)}
        </span>
      ) : null
    }
    {
      hasAllergens ? (
        <span class={variant === "headless" ? undefined : "rounded-full bg-stone-100 px-3 py-1 text-stone-700"}>
          Contains: {formatAllergens(item.allergens)}
        </span>
      ) : null
    }
  </div>
</article>
