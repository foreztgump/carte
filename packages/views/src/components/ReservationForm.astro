---
import { reservationClassesFor } from "../styles.js";
import type { ReservationFormProps } from "../types.js";

const props = Astro.props as ReservationFormProps;
const {
  action,
  defaultDate,
  defaultTime,
  partySizeOptions = [1, 2, 3, 4, 5, 6],
  variant = "default",
} = props;
const formClass = reservationClassesFor(variant);
const fieldClass =
  variant === "headless"
    ? undefined
    : "mt-1 w-full rounded-lg border border-stone-300 px-3 py-2 text-sm";
const labelClass = variant === "headless" ? undefined : "text-sm font-medium text-stone-950";
---

<section aria-labelledby="carte-reservation-heading" class={formClass} data-carte-variant={variant}>
  <h2
    class={variant === "headless" ? undefined : "text-lg font-semibold text-stone-950"}
    id="carte-reservation-heading"
  >
    Request a reservation
  </h2>
  <!--
    Reservation submission pattern (SG7-compliant):
    Component is prop-driven and never fetches. Submission is a standard
    form POST to the host-supplied `action` endpoint. The host page is
    responsible for handling the response (success/redirect/error copy).
  -->
  <form
    action={action}
    class={variant === "headless" ? undefined : "mt-4 grid gap-4"}
    data-carte-reservation-form
    method="post"
  >
    <label class={labelClass}>
      Name
      <input autocomplete="name" class={fieldClass} name="name" required type="text" />
    </label>
    <label class={labelClass}>
      Email
      <input autocomplete="email" class={fieldClass} name="email" required type="email" />
    </label>
    <label class={labelClass}>
      Phone
      <input autocomplete="tel" class={fieldClass} name="phone" type="tel" />
    </label>
    <div class={variant === "headless" ? undefined : "grid gap-4 sm:grid-cols-3"}>
      <label class={labelClass}>
        Date
        <input class={fieldClass} name="date" required type="date" value={defaultDate} />
      </label>
      <label class={labelClass}>
        Time
        <input class={fieldClass} name="time" required type="time" value={defaultTime} />
      </label>
      <label class={labelClass}>
        Party size
        <select class={fieldClass} name="partySize" required>
          {partySizeOptions.map((size) => <option value={String(size)}>{size}</option>)}
        </select>
      </label>
    </div>
    <label class={labelClass}>
      Notes
      <textarea class={fieldClass} name="notes" rows="3"></textarea>
    </label>
    <button
      class={variant === "headless" ? undefined : "rounded-full bg-amber-700 px-5 py-3 text-sm font-semibold text-white"}
      type="submit"
    >
      Request reservation
    </button>
    <p aria-live="polite" data-carte-reservation-status role="status"></p>
    <p data-carte-reservation-error hidden role="alert"></p>
  </form>
</section>
