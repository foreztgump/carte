{
  "name": "@carte/views",
  "version": "0.3.0",
  "description": "Carte views — Astro/React component peer-dep library for storefronts. NOT an EmDash plugin.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components/CarteShell.astro": "./dist/components/CarteShell.astro",
    "./components/DietaryFilter.astro": "./dist/components/DietaryFilter.astro",
    "./components/HoursWidget.astro": "./dist/components/HoursWidget.astro",
    "./components/MenuDisplay.astro": "./dist/components/MenuDisplay.astro",
    "./components/MenuItem.astro": "./dist/components/MenuItem.astro",
    "./components/MenuSection.astro": "./dist/components/MenuSection.astro",
    "./components/OrderingCart.astro": "./dist/components/OrderingCart.astro",
    "./components/OrderingCheckout.astro": "./dist/components/OrderingCheckout.astro",
    "./components/OrderRecordStatus.astro": "./dist/components/OrderRecordStatus.astro",
    "./components/ReservationForm.astro": "./dist/components/ReservationForm.astro",
    "./components/ReservationRecordStatus.astro": "./dist/components/ReservationRecordStatus.astro",
    "./components/RestaurantHero.astro": "./dist/components/RestaurantHero.astro",
    "./components/RestaurantInfo.astro": "./dist/components/RestaurantInfo.astro"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "astro:check": "astro check",
    "typecheck": "tsc --noEmit && astro check",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "astro": ">=5.10.0 <7"
  },
  "dependencies": {
    "@carte/core": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "astro": "6.3.1",
    "tsdown": "0.20.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
