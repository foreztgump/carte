{
  "name": "@carte/views",
  "version": "0.1.0",
  "private": true,
  "description": "Carte views — Astro/React component peer-dep library for storefronts. NOT an EmDash plugin.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/CarteShell.astro": "./src/components/CarteShell.astro",
    "./components/DietaryFilter.astro": "./src/components/DietaryFilter.astro",
    "./components/HoursWidget.astro": "./src/components/HoursWidget.astro",
    "./components/MenuDisplay.astro": "./src/components/MenuDisplay.astro",
    "./components/MenuItem.astro": "./src/components/MenuItem.astro",
    "./components/MenuSection.astro": "./src/components/MenuSection.astro",
    "./components/OrderingCart.astro": "./src/components/OrderingCart.astro",
    "./components/OrderingCheckout.astro": "./src/components/OrderingCheckout.astro",
    "./components/OrderRecordStatus.astro": "./src/components/OrderRecordStatus.astro",
    "./components/ReservationForm.astro": "./src/components/ReservationForm.astro",
    "./components/ReservationRecordStatus.astro": "./src/components/ReservationRecordStatus.astro",
    "./components/RestaurantHero.astro": "./src/components/RestaurantHero.astro",
    "./components/RestaurantInfo.astro": "./src/components/RestaurantInfo.astro"
  },
  "scripts": {
    "astro:check": "astro check",
    "typecheck": "tsc --noEmit && astro check",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "astro": ">=5.10.0 <7"
  },
  "dependencies": {
    "@carte/core": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "astro": "6.3.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
