{
  "name": "@carte/orders-admin",
  "version": "0.3.0",
  "description": "Carte orders admin — native React UI for the orders queue. EmDash native plugin.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./admin": {
      "types": "./dist/admin/index.d.mts",
      "default": "./dist/admin/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "emdash": "^0.18"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.1.1",
    "tsdown": "0.20.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "dependencies": {
    "@carte/core": "workspace:*",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
