{
  "name": "@carte/core",
  "version": "0.3.0",
  "description": "Carte core — menus, restaurant settings, hours, schema.org JSON-LD. Sandboxed EmDash plugin.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "exports": {
    ".": "./dist/index.mjs",
    "./sandbox": "./dist/plugin.mjs",
    "./contracts": "./src/contracts.ts",
    "./taxonomy": "./src/taxonomy/allergens.ts",
    "./taxonomy/allergens": "./src/taxonomy/allergens.ts"
  },
  "files": [
    "dist",
    "emdash-plugin.jsonc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "emdash-plugin build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "emdash": "^0.18"
  },
  "devDependencies": {
    "@emdash-cms/plugin-cli": "0.5.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}
