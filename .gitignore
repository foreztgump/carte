# Per-worktree workflow state (used by /work, /mission hooks).
# These files are local to a worktree and do not belong in source.
.factory-state/

# Editor / OS noise
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Future-proof for Milestone 2 (no harm pre-scaffold)
node_modules/
dist/
.astro/
.wrangler/
.dev.vars
coverage/
*.tsbuildinfo

# Wrangler-generated runtime types (regenerated by `wrangler types`)
packages/*/worker-configuration.d.ts

# Playwright MCP scratch output
.playwright-mcp/

# Loose validation render screenshots dropped at repo root (committed copies live
# under each milestone's validation/ dir referenced from tasks.md)
/pro*-*.png
