{
  "name": "carte",
  "private": true,
  "version": "0.0.1",
  "description": "Carte — EmDash restaurant plugin family (workspace root).",
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "test:e2e": "node scripts/run-playwright.mjs",
    "e2e:ui": "playwright test --ui",
    "verify:rich-results": "tsx scripts/verify-rich-results.ts",
    "audit:sandbox-budget": "tsx scripts/audit-sandbox-budget.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@emdash-cms/plugin-cli": "0.5.1",
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.0",
    "emdash": "^0.18",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.1",
    "schema-dts": "2.0.0",
    "tsdown": "0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.6",
    "wrangler": "^4.88.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "react": "19.2.6",
      "react-dom": "19.2.6"
    },
    "patchedDependencies": {
      "@emdash-cms/sandbox-workerd@0.1.6": "patches/@emdash-cms__sandbox-workerd@0.1.6.patch"
    }
  }
}
