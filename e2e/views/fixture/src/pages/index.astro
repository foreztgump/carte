---
import DietaryFilter from "@carte/views/components/DietaryFilter.astro";
import HoursWidget from "@carte/views/components/HoursWidget.astro";
import MenuDisplay from "@carte/views/components/MenuDisplay.astro";
import OrderingCart from "@carte/views/components/OrderingCart.astro";
import OrderingCheckout from "@carte/views/components/OrderingCheckout.astro";
import ReservationForm from "@carte/views/components/ReservationForm.astro";
import RestaurantHero from "@carte/views/components/RestaurantHero.astro";
import RestaurantInfo from "@carte/views/components/RestaurantInfo.astro";

const restaurant = {
  name: "Juniper Table",
  tagline: "Seasonal Cal-Mediterranean plates",
  heroImage: {
    alt: "Colorful plates on a restaurant table",
    src: "/hero.jpg",
  },
  cuisine: ["California", "Mediterranean"],
  priceRange: "$$",
};

const info = {
  addressLines: ["123 Market Street", "Harbor City, CA"],
  phone: "(555) 010-4141",
  email: "hello@junipertable.example",
};

const menu = {
  id: "dinner",
  name: "Dinner",
  sections: [
    {
      id: "starters",
      name: "Starters",
      description: "Bright first plates for the table.",
      items: [
        {
          id: "broccolini",
          name: "Charred Broccolini",
          description: "Lemon tahini, almond crunch, preserved chile.",
          price: 1400,
          currency: "USD",
          allergens: ["undeclared-tree-nuts"],
          dietaryTags: ["vegan", "gluten_free"],
        },
        {
          id: "salad",
          name: "Citrus Salad",
          description: "Cara cara orange, fennel, mint, olive oil.",
          price: 1200,
          currency: "USD",
          allergens: [],
          dietaryTags: ["vegan", "gluten_free"],
        },
      ],
    },
  ],
};

const hours = [
  { day: "monday", opensAt: "17:00", closesAt: "22:00" },
  { day: "tuesday", opensAt: "17:00", closesAt: "22:00" },
  { day: "wednesday", opensAt: "17:00", closesAt: "22:00" },
  { day: "thursday", opensAt: "17:00", closesAt: "23:00" },
  { day: "friday", opensAt: "17:00", closesAt: "23:00" },
  { day: "saturday", opensAt: "16:00", closesAt: "23:00" },
  { day: "sunday", closed: true },
];

const orderingCart = {
  id: "cart-fixture",
  currency: "USD",
  lineItems: [
    {
      id: "line-broccolini",
      menuItemId: "broccolini",
      name: "Charred Broccolini",
      quantity: 2,
      unitPrice: 1400,
      modifiers: [{ id: "extra-almonds", name: "Extra almond crunch", price: 200 }],
    },
    {
      id: "line-salad",
      menuItemId: "salad",
      name: "Citrus Salad",
      quantity: 1,
      unitPrice: 1200,
      modifiers: [],
    },
  ],
  totals: {
    subtotal: 4400,
    tax: 396,
    serviceFee: 250,
    total: 5046,
  },
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Carte Views Menu Fixture</title>
  </head>
  <body>
    <main>
      <RestaurantHero restaurant={restaurant} />
      <RestaurantInfo info={info} />
      <HoursWidget hours={hours} today="thursday" />
      <!-- Intentionally unknown allergen tag to exercise @carte/core's humanized fallback path. -->
      <DietaryFilter allergens={["undeclared-tree-nuts"]} targetMenuId={menu.id} />
      <MenuDisplay menu={menu} />
      <OrderingCart cart={orderingCart} />
      <OrderingCheckout action="/_emdash/api/plugins/carte-orders-backend/checkout" cart={orderingCart} />
      <ReservationForm
        action="/_emdash/api/plugins/carte-reservations/submit"
        defaultDate="2026-05-14"
        defaultTime="19:00"
        partySizeOptions={[2, 4, 6]}
      />
    </main>
    <script is:inline>
      // Host-page checkout orchestration. @carte/views components are
      // prop-driven and never fetch (SG7), so the storefront owns the POST,
      // the open-redirect-safe navigation to the Tender checkout URL, and
      // threading the returned `transactionId` to the success page so the
      // return route can drive fulfillment.
      const SUCCESS_PATH = "/order-success";
      const TRANSACTION_KEY = "carte:last-transaction";
      const ALLOWED_CHECKOUT_HOSTS = ["checkout.stripe.com"];
      const checkoutForm = document.querySelector("[data-carte-checkout-form]");
      const orderId = "order_fixture_1001";

      const safeCheckoutUrl = (raw) => {
        let url;
        try {
          url = new URL(raw);
        } catch {
          return null;
        }
        if (url.protocol !== "https:" || !ALLOWED_CHECKOUT_HOSTS.includes(url.host)) {
          return null;
        }
        return url.toString();
      };

      checkoutForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const statusEl = checkoutForm.querySelector("[data-carte-checkout-status]");
        const errorEl = checkoutForm.querySelector("[data-carte-checkout-error]");
        const form = new FormData(checkoutForm);
        const successUrl = new URL(SUCCESS_PATH, globalThis.location.origin);
        successUrl.searchParams.set("orderId", orderId);

        try {
          const response = await fetch(checkoutForm.getAttribute("action"), {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({
              cartId: "cart-fixture",
              orderId,
              customerEmail: form.get("email"),
              successUrl: successUrl.toString(),
              cancelUrl: globalThis.location.href,
              lineItems: [{ name: "Charred Broccolini", unitAmount: 1400, quantity: 2 }],
            }),
          });
          const payload = await response.json();
          const target = safeCheckoutUrl(payload?.checkoutUrl);
          if (!target) {
            if (errorEl) {
              errorEl.hidden = false;
              errorEl.textContent = "Checkout is unavailable. Please try again.";
            }
            return;
          }
          // Persist the id only once the redirect target is trusted; Tender may
          // not append a verifiable id to the return URL, so sessionStorage is
          // the production carrier the success page reads back.
          if (payload?.transactionId) {
            globalThis.sessionStorage?.setItem(TRANSACTION_KEY, payload.transactionId);
          }
          if (statusEl) statusEl.textContent = "Redirecting to secure payment…";
          globalThis.location.assign(target);
        } catch {
          if (errorEl) {
            errorEl.hidden = false;
            errorEl.textContent = "Checkout is unavailable. Please try again.";
          }
        }
      });

      // Host-page reservation orchestration. The ReservationForm is likewise
      // fetch-free, so the storefront owns the POST and renders the success
      // copy or the validation error returned by the reservations route.
      const reservationForm = document.querySelector("[data-carte-reservation-form]");

      reservationForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const statusEl = reservationForm.querySelector("[data-carte-reservation-status]");
        const errorEl = reservationForm.querySelector("[data-carte-reservation-error]");
        const form = new FormData(reservationForm);
        if (statusEl) statusEl.textContent = "";
        if (errorEl) errorEl.hidden = true;

        try {
          const response = await fetch(reservationForm.getAttribute("action"), {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(Object.fromEntries(form.entries())),
          });
          const payload = await response.json();
          if (response.ok) {
            if (statusEl) statusEl.textContent = payload?.message ?? "Reservation request received.";
            return;
          }
          if (errorEl) {
            errorEl.hidden = false;
            errorEl.textContent = payload?.message ?? "Reservation request failed.";
          }
        } catch {
          if (errorEl) {
            errorEl.hidden = false;
            errorEl.textContent = "Reservation request failed.";
          }
        }
      });
    </script>
  </body>
</html>
